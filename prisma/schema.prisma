generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AppUser {
  id       String  @id @default(cuid())
  email    String  @unique
  name     String?
  username String? @unique // for friend search, set during onboarding

  workoutData WorkoutData?
  healthConn  HealthConnection?

  // Profile
  status          String?   // short status message
  statusExpiresAt DateTime? // null = indefinite; set = expires at this time
  showcaseBadges  Json?     // string[] of badge slugs, ordered, max 8

  // Social
  sentRequests   Friendship[] @relation("FriendRequester")
  recvRequests   Friendship[] @relation("FriendReceiver")
  badges         Badge[]
  coinWallet     CoinWallet?
  sentChallenges Challenge[]  @relation("Challenger")
  recvChallenges Challenge[]  @relation("Challengee")
  wonChallenges  Challenge[]  @relation("ChallengeWinner")
  dayRecords     DayRecord[]
  pushSubs       PushSubscription[]
  ownedGroups      Group[]       @relation("GroupOwner")
  groupMemberships GroupMember[] @relation("GroupMembership")
  teamBattlesCreated TeamBattle[]            @relation("TeamBattleCreator")
  teamBattleParts    TeamBattleParticipant[] @relation("TeamBattleParticipant")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A user-created roster of friends for team battles. You can add anyone you're
// friends with; members don't need to be friends with each other.
model Group {
  id      String        @id @default(cuid())
  name    String
  ownerId String
  owner   AppUser       @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members GroupMember[]
  teamBattles TeamBattle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model GroupMember {
  id      String  @id @default(cuid())
  groupId String
  userId  String
  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    AppUser @relation("GroupMembership", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

// A team-vs-team typed battle within a group (2v2 … up to size/2 v size/2).
// Reuses the typed-battle category engine; team score per category = sum of
// each member's score (restricted to 'higher-is-better' categories so a
// non-logger contributes 0 and hurts their own team).
model TeamBattle {
  id          String    @id @default(cuid())
  groupId     String
  creatorId   String
  wager       Int       @default(0)        // coins anted by EACH participant
  bestOf      Int                          // 1 | 3 | 5 == categories.length
  windowKind  String                       // 'day' | 'week'
  startDate   String                       // YYYY-MM-DD inclusive
  endDate     String                       // YYYY-MM-DD inclusive
  categories  Json                          // string[] of category slugs
  // pending  → invitees still accepting (each accept escrows their wager)
  // active   → everyone accepted, awaiting endDate
  // resolved → winning team computed, pot distributed
  // cancelled → declined / creator-cancelled / expired before active → refunded
  status      String    @default("pending")
  winningTeam Int?                          // 0 | 1, null = tie / unresolved
  resolution  Json?                         // per-category team scoreboard
  resolvedAt  DateTime?

  group        Group                   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator      AppUser                 @relation("TeamBattleCreator", fields: [creatorId], references: [id])
  participants TeamBattleParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, endDate])
  @@index([groupId])
}

model TeamBattleParticipant {
  id       String  @id @default(cuid())
  battleId String
  userId   String
  team     Int                          // 0 or 1
  accepted Boolean @default(false)       // true once they've anted their wager

  battle TeamBattle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  user   AppUser    @relation("TeamBattleParticipant", fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([battleId, userId])
  @@index([userId])
}

model WorkoutData {
  id     String  @id @default(cuid())
  userId String  @unique
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  localDB  Json @default("{}")
  profile  Json @default("{}")
  settings Json @default("{}")

  syncedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HealthConnection {
  id     String  @id @default(cuid())
  userId String  @unique
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  googleAccessToken  String?
  googleRefreshToken String?
  googleExpiresAt    DateTime?
  googleScope        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Day Records (normalised workout/food log — replaces WorkoutData.localDB blob) ──

model DayRecord {
  id     String  @id @default(cuid())
  userId String
  date   String  // YYYY-MM-DD
  data   Json    @default("{}")

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
}

// ── Push Notifications ─────────────────────────────────────────────────────────

model PushSubscription {
  id       String  @id @default(cuid())
  userId   String
  endpoint String
  p256dh   String
  auth     String

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, endpoint])
  @@index([userId])
}

// ── Social ─────────────────────────────────────────────────────────────────────

model Friendship {
  id          String @id @default(cuid())
  requesterId String
  receiverId  String
  // pending | accepted | rejected
  status      String @default("pending")

  requester AppUser @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  AppUser @relation("FriendReceiver",  fields: [receiverId],  references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([requesterId, receiverId])
  @@index([receiverId])
}

// ── Badges ─────────────────────────────────────────────────────────────────────

model Badge {
  id       String @id @default(cuid())
  userId   String
  // lift | cardio | nutrition
  category String
  // e.g. bench_225 | squat_315 | streak_30
  slug     String
  label    String
  icon     String @default("🏅")

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  earnedAt DateTime @default(now())

  @@unique([userId, slug])
  @@index([userId])
}

// ── Coins (server-authoritative for competitive play) ──────────────────────────

model CoinWallet {
  id      String @id @default(cuid())
  userId  String @unique
  balance Int    @default(0)

  user         AppUser         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CoinTransaction[]
}

model CoinTransaction {
  id       String  @id @default(cuid())
  walletId String
  // positive = credit, negative = debit
  amount   Int
  // goal_hit | badge_earned | battle_win | battle_loss | battle_bet | refund
  reason   String
  refId    String? // Challenge.id if from a battle

  wallet CoinWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([walletId])
}

// ── Battles ────────────────────────────────────────────────────────────────────

model Challenge {
  id           String    @id @default(cuid())
  challengerId String
  challengeeId String
  wager        Int       @default(0)   // coins bet by each side
  // pending  → both wagers held, challengee hasn't responded
  // active   → accepted, awaiting endDate before resolution
  // resolved → winner computed, coins transferred
  // cancelled → declined or refunded
  status       String    @default("pending")
  // For typed battles: array of category slugs (length === bestOf).
  // For legacy battles: ["all"] — resolution falls back to badge-count comparison.
  categories   Json
  winnerId     String?
  resolvedAt   DateTime?

  // ── Typed-battle fields (null on legacy badge-count battles) ─────────────
  // 'classic' = badge-count comparison (existing behavior, instant resolve on accept)
  // 'typed'   = per-category stat comparison with a measurement window
  type         String?
  bestOf       Int?      // 1 | 3 | 5 — must equal categories.length for typed battles
  windowKind   String?   // 'day' | 'week'
  startDate    String?   // YYYY-MM-DD — first day of the measurement window (inclusive)
  endDate      String?   // YYYY-MM-DD — last day of the measurement window (inclusive)
  // Per-category resolution snapshot, populated when status becomes 'resolved':
  //   { perCategory: [{ slug, label, group, direction, unit, challengerScore, challengeeScore, winnerId|null }], summary: { challengerWins, challengeeWins, ties } }
  resolution   Json?

  challenger AppUser  @relation("Challenger",      fields: [challengerId], references: [id])
  challengee AppUser  @relation("Challengee",      fields: [challengeeId], references: [id])
  winner     AppUser? @relation("ChallengeWinner", fields: [winnerId],     references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([challengerId])
  @@index([challengeeId])
  // Lets the resolve-battles cron sweep efficiently for completed windows.
  @@index([status, endDate])
}
